{
  "name": "makemyai-global",
  "version": "0.1.0",
  "private": true,
  "description": "Karr AI - AI Factory Platform",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @makemyai/web dev",
    "dev:mobile": "pnpm --filter @makemyai/mobile start",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @makemyai/web build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean && rimraf node_modules",
    "db:generate-types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > packages/database/src/types.ts",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "functions:serve": "supabase functions serve",
    "functions:deploy": "supabase functions deploy"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.12.0"
}
