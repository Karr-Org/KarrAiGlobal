{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "allowJs": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "isolatedModules": true,
        "incremental": true,
        "declaration": true,
        "declarationMap": true,
        "composite": false,
        "paths": {
            "@karrai/database": [
                "./packages/database/src"
            ],
            "@karrai/ai": [
                "./packages/ai/src"
            ],
            "@karrai/rag": [
                "./packages/rag/src"
            ],
            "@karrai/ui": [
                "./packages/ui/src"
            ]
        }
    },
    "exclude": [
        "node_modules",
        "**/node_modules",
        "**/.next",
        "**/dist"
    ]
}